defines = -DNDEBUG
framework_dirs =
include_dirs =
label_name = crashpad_test_test
target_output_name = crashpad_test_test


build ./crashpad_test_test: link obj/test/test_test.hex_string_test.o obj/test/test_test.main_arguments_test.o obj/test/test_test.multiprocess_exec_test.o obj/test/test_test.scoped_guarded_page_test.o obj/test/test_test.scoped_temp_dir_test.o obj/test/test_test.test_paths_test.o obj/test/test_test.multiprocess_posix_test.o obj/test/mac/test_test.mach_multiprocess_test.o obj/tools/tool_support.tool_support.o obj/test/libgooglemock_main.a obj/test/libtest.a obj/third_party/mini_chromium/mini_chromium/base/libbase.a obj/third_party/googletest/libgoogletest.a obj/util/libutil.a obj/util/libmig_output.a obj/handler/libhandler.a obj/handler/libcommon.a obj/client/libcommon.a obj/minidump/libminidump.a obj/minidump/libformat.a obj/snapshot/libcontext.a obj/snapshot/libsnapshot.a obj/util/libnet.a obj/client/libclient.a obj/third_party/googletest/libgooglemock.a || obj/test/test_test.stamp obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/util/no_cfi_icall.stamp obj/third_party/zlib/zlib.stamp obj/tools/tool_support.stamp
  ldflags = -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk -arch arm64 -mmacosx-version-min=12.0 -Wl,-dead_strip
  libs = -lbsm -lz
  frameworks = -framework CoreFoundation -framework Foundation -framework Security -framework ApplicationServices -framework IOKit
  swiftmodules =
  output_extension = 
  output_dir = .
