defines = -DNDEBUG -DCRASHPAD_ZLIB_SOURCE_SYSTEM
framework_dirs =
include_dirs = -I../../OrginPackage/crashpad-main -Igen -I../../OrginPackage/crashpad-main/third_party/mini_chromium/mini_chromium -I../../OrginPackage/crashpad-main/compat/mac -I../../OrginPackage/crashpad-main/compat/non_win
cflags = -Wall -Werror -Wextra -fno-exceptions -fno-rtti -fno-strict-aliasing -fobjc-call-cxx-cdtors -fstack-protector-all -fvisibility-inlines-hidden -fvisibility=hidden -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk -arch arm64 -mmacosx-version-min=12.0 -O3 -Wexit-time-destructors -Wimplicit-fallthrough
cflags_cc = -std=c++23
label_name = client
target_output_name = libclient

build obj/client/client.prune_crash_reports.o: cxx ../../OrginPackage/crashpad-main/client/prune_crash_reports.cc || obj/util/mig.stamp
build obj/client/client.crashpad_client_mac.o: cxx ../../OrginPackage/crashpad-main/client/crashpad_client_mac.cc || obj/util/mig.stamp
build obj/client/client.simulate_crash_mac.o: cxx ../../OrginPackage/crashpad-main/client/simulate_crash_mac.cc || obj/util/mig.stamp

build obj/client/libclient.a: alink obj/client/client.prune_crash_reports.o obj/client/client.crashpad_client_mac.o obj/client/client.simulate_crash_mac.o || obj/client/libcommon.a obj/third_party/mini_chromium/base.stamp obj/util/libutil.a obj/build/apple_enable_arc.stamp obj/third_party/mini_chromium/mini_chromium/base/libbase.a obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/util/no_cfi_icall.stamp obj/third_party/zlib/zlib.stamp obj/util/libmig_output.a
  arflags =
  output_extension = .a
  output_dir = obj/client
