build obj/client/client_test.prune_crash_reports_test.o: cxx ../../OrginPackage/crashpad-main/client/prune_crash_reports_test.cc || obj/util/mig.stamp
build obj/client/client_test.ring_buffer_annotation_test.o: cxx ../../OrginPackage/crashpad-main/client/ring_buffer_annotation_test.cc || obj/util/mig.stamp
build obj/client/client_test.settings_test.o: cxx ../../OrginPackage/crashpad-main/client/settings_test.cc || obj/util/mig.stamp
build obj/client/client_test.simple_address_range_bag_test.o: cxx ../../OrginPackage/crashpad-main/client/simple_address_range_bag_test.cc || obj/util/mig.stamp
build obj/client/client_test.simple_string_dictionary_test.o: cxx ../../OrginPackage/crashpad-main/client/simple_string_dictionary_test.cc || obj/util/mig.stamp
build obj/client/client_test.simulate_crash_mac_test.o: cxx ../../OrginPackage/crashpad-main/client/simulate_crash_mac_test.cc || obj/util/mig.stamp

build obj/client/client_test.stamp: stamp obj/client/client_test.annotation_list_test.o obj/client/client_test.annotation_test.o obj/client/client_test.crash_report_database_test.o obj/client/client_test.crashpad_info_test.o obj/client/client_test.length_delimited_ring_buffer_test.o obj/client/client_test.prune_crash_reports_test.o obj/client/client_test.ring_buffer_annotation_test.o obj/client/client_test.settings_test.o obj/client/client_test.simple_address_range_bag_test.o obj/client/client_test.simple_string_dictionary_test.o obj/client/client_test.simulate_crash_mac_test.o || obj/client/libclient.a obj/third_party/mini_chromium/base.stamp obj/compat/compat.stamp obj/snapshot/libsnapshot.a obj/test/libtest.a obj/third_party/googletest/libgoogletest.a obj/third_party/googletest/libgooglemock.a obj/util/libutil.a obj/build/apple_enable_arc.stamp obj/client/libcommon.a obj/third_party/mini_chromium/mini_chromium/base/libbase.a obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/util/no_cfi_icall.stamp obj/third_party/zlib/zlib.stamp obj/util/libmig_output.a obj/snapshot/libcontext.a obj/minidump/libformat.a obj/handler/libhandler.a obj/handler/libcommon.a obj/minidump/libminidump.a obj/util/libnet.a obj/tools/tool_support.stamp ./crashpad_handler
