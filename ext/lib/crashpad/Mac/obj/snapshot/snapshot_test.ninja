build obj/snapshot/mac/snapshot_test.system_snapshot_mac_test.o: cxx ../../OrginPackage/crashpad-main/snapshot/mac/system_snapshot_mac_test.cc || obj/util/mig.stamp
build obj/snapshot/snapshot_test.crashpad_info_client_options_test.o: cxx ../../OrginPackage/crashpad-main/snapshot/crashpad_info_client_options_test.cc || obj/util/mig.stamp
build obj/snapshot/posix/snapshot_test.timezone_test.o: cxx ../../OrginPackage/crashpad-main/snapshot/posix/timezone_test.cc || obj/util/mig.stamp

build obj/snapshot/snapshot_test.stamp: stamp obj/snapshot/snapshot_test.cpu_context_test.o obj/snapshot/snapshot_test.memory_snapshot_test.o obj/snapshot/minidump/snapshot_test.process_snapshot_minidump_test.o obj/snapshot/mac/snapshot_test.cpu_context_mac_test.o obj/snapshot/mac/snapshot_test.mach_o_image_annotations_reader_test.o obj/snapshot/mac/snapshot_test.mach_o_image_reader_test.o obj/snapshot/mac/snapshot_test.mach_o_image_segment_reader_test.o obj/snapshot/mac/snapshot_test.process_reader_mac_test.o obj/snapshot/mac/snapshot_test.process_types_test.o obj/snapshot/mac/snapshot_test.system_snapshot_mac_test.o obj/snapshot/snapshot_test.crashpad_info_client_options_test.o obj/snapshot/posix/snapshot_test.timezone_test.o || obj/snapshot/libtest_support.a obj/third_party/mini_chromium/base.stamp obj/client/libcommon.a obj/compat/compat.stamp obj/minidump/libformat.a obj/test/libtest.a obj/third_party/googletest/libgoogletest.a obj/third_party/googletest/libgooglemock.a obj/util/libutil.a obj/snapshot/libsnapshot.a obj/snapshot/libcontext.a obj/third_party/mini_chromium/mini_chromium/base/libbase.a obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/util/no_cfi_icall.stamp obj/third_party/zlib/zlib.stamp obj/util/libmig_output.a obj/handler/libhandler.a obj/handler/libcommon.a obj/minidump/libminidump.a obj/util/libnet.a obj/client/libclient.a obj/tools/tool_support.stamp ./crashpad_snapshot_test_module.so ./crashpad_snapshot_test_module_large.so ./crashpad_snapshot_test_module_small.so ./crashpad_snapshot_test_module_crashy_initializer.so ./crashpad_snapshot_test_no_op
