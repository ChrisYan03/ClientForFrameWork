defines = -DNDEBUG -DCRASHPAD_ZLIB_SOURCE_SYSTEM
framework_dirs =
include_dirs = -I../../OrginPackage/crashpad-main/third_party/mini_chromium/mini_chromium -Igen -I../../OrginPackage/crashpad-main -I../../OrginPackage/crashpad-main/compat/mac -I../../OrginPackage/crashpad-main/compat/non_win
cflags = -Wall -Werror -Wextra -fno-exceptions -fno-rtti -fno-strict-aliasing -fobjc-call-cxx-cdtors -fstack-protector-all -fvisibility-inlines-hidden -fvisibility=hidden -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk -arch arm64 -mmacosx-version-min=12.0 -O3 -Wexit-time-destructors -Wimplicit-fallthrough
cflags_cc = -std=c++23
label_name = crashpad_snapshot_test_module
target_output_name = crashpad_snapshot_test_module

build obj/snapshot/crashpad_snapshot_test_module.crashpad_info_client_options_test_module.o: cxx ../../OrginPackage/crashpad-main/snapshot/crashpad_info_client_options_test_module.cc || obj/util/mig.stamp

build ./crashpad_snapshot_test_module.so: solink_module obj/snapshot/crashpad_snapshot_test_module.crashpad_info_client_options_test_module.o obj/client/libclient.a obj/third_party/mini_chromium/mini_chromium/base/libbase.a obj/client/libcommon.a obj/util/libutil.a obj/util/libmig_output.a || obj/third_party/mini_chromium/base.stamp obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/util/no_cfi_icall.stamp obj/third_party/zlib/zlib.stamp
  ldflags = -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk -arch arm64 -mmacosx-version-min=12.0 -Wl,-dead_strip
  libs = -lbsm -lz
  frameworks = -framework CoreFoundation -framework Foundation -framework Security -framework ApplicationServices -framework IOKit
  swiftmodules =
  output_extension = .so
  output_dir = .
