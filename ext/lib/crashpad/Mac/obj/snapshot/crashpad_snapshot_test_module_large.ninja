defines = -DCRASHPAD_INFO_SIZE_TEST_MODULE_LARGE -DNDEBUG
framework_dirs =
include_dirs = -I../../OrginPackage/crashpad-main/third_party/mini_chromium/mini_chromium -Igen
cflags = -Wall -Werror -Wextra -fno-exceptions -fno-rtti -fno-strict-aliasing -fobjc-call-cxx-cdtors -fstack-protector-all -fvisibility-inlines-hidden -fvisibility=hidden -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk -arch arm64 -mmacosx-version-min=12.0 -O3 -Wexit-time-destructors -Wimplicit-fallthrough
cflags_cc = -std=c++23
label_name = crashpad_snapshot_test_module_large
target_output_name = crashpad_snapshot_test_module_large

build obj/snapshot/crashpad_snapshot_test_module_large.crashpad_info_size_test_module.o: cxx ../../OrginPackage/crashpad-main/snapshot/crashpad_info_size_test_module.cc

build ./crashpad_snapshot_test_module_large.so: solink_module obj/snapshot/crashpad_snapshot_test_module_large.crashpad_info_size_test_module.o obj/third_party/mini_chromium/mini_chromium/base/libbase.a || obj/third_party/mini_chromium/base.stamp obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp
  ldflags = -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk -arch arm64 -mmacosx-version-min=12.0 -Wl,-dead_strip
  libs =
  frameworks = -framework CoreFoundation -framework Foundation -framework Security -framework ApplicationServices -framework IOKit
  swiftmodules =
  output_extension = .so
  output_dir = .
