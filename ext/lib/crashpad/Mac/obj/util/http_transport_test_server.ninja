defines = -DNDEBUG -DCRASHPAD_ZLIB_SOURCE_SYSTEM
framework_dirs =
include_dirs = -I../../OrginPackage/crashpad-main -Igen -I../../OrginPackage/crashpad-main/third_party/mini_chromium/mini_chromium -I../../OrginPackage/crashpad-main/compat/mac -I../../OrginPackage/crashpad-main/compat/non_win
cflags = -Wall -Werror -Wextra -fno-exceptions -fno-rtti -fno-strict-aliasing -fobjc-call-cxx-cdtors -fstack-protector-all -fvisibility-inlines-hidden -fvisibility=hidden -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk -arch arm64 -mmacosx-version-min=12.0 -O3 -Wimplicit-fallthrough
cflags_cc = -std=c++23
label_name = http_transport_test_server
target_output_name = http_transport_test_server

build obj/util/net/http_transport_test_server.http_transport_test_server.o: cxx ../../OrginPackage/crashpad-main/util/net/http_transport_test_server.cc || obj/util/mig.stamp

build ./http_transport_test_server: link obj/util/net/http_transport_test_server.http_transport_test_server.o obj/tools/tool_support.tool_support.o obj/util/libnet.a obj/util/libutil.a obj/third_party/mini_chromium/mini_chromium/base/libbase.a obj/util/libmig_output.a || obj/third_party/mini_chromium/base.stamp obj/third_party/cpp-httplib/cpp-httplib.stamp obj/third_party/zlib/zlib.stamp obj/tools/tool_support.stamp obj/util/no_cfi_icall.stamp obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp
  ldflags = -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk -arch arm64 -mmacosx-version-min=12.0 -Wl,-dead_strip
  libs = -lbsm -lz
  frameworks = -framework CoreFoundation -framework Foundation -framework IOKit -framework Security -framework ApplicationServices
  swiftmodules =
  output_extension = 
  output_dir = .
