defines = -DNDEBUG
framework_dirs =
include_dirs = -I../../OrginPackage/crashpad-main/third_party/googletest/googletest/googletest/include
cflags = -Wall -Werror -Wextra -fno-exceptions -fno-rtti -fno-strict-aliasing -fobjc-call-cxx-cdtors -fstack-protector-all -fvisibility-inlines-hidden -fvisibility=hidden -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk -arch arm64 -mmacosx-version-min=12.0 -O3 -Wexit-time-destructors -Wimplicit-fallthrough
cflags_cc = -std=c++23
label_name = googletest_main
target_output_name = libgoogletest_main

build obj/third_party/googletest/googletest/googletest/src/googletest_main.gtest_main.o: cxx ../../OrginPackage/crashpad-main/third_party/googletest/googletest/googletest/src/gtest_main.cc

build obj/third_party/googletest/libgoogletest_main.a: alink obj/third_party/googletest/googletest/googletest/src/googletest_main.gtest_main.o || obj/third_party/googletest/libgoogletest.a
  arflags =
  output_extension = .a
  output_dir = obj/third_party/googletest
