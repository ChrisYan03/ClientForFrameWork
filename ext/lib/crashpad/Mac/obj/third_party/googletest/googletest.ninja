build obj/third_party/googletest/googletest/googletest/src/googletest.gtest-filepath.o: cxx ../../OrginPackage/crashpad-main/third_party/googletest/googletest/googletest/src/gtest-filepath.cc
build obj/third_party/googletest/googletest/googletest/src/googletest.gtest-matchers.o: cxx ../../OrginPackage/crashpad-main/third_party/googletest/googletest/googletest/src/gtest-matchers.cc
build obj/third_party/googletest/googletest/googletest/src/googletest.gtest-port.o: cxx ../../OrginPackage/crashpad-main/third_party/googletest/googletest/googletest/src/gtest-port.cc
build obj/third_party/googletest/googletest/googletest/src/googletest.gtest-printers.o: cxx ../../OrginPackage/crashpad-main/third_party/googletest/googletest/googletest/src/gtest-printers.cc
build obj/third_party/googletest/googletest/googletest/src/googletest.gtest-test-part.o: cxx ../../OrginPackage/crashpad-main/third_party/googletest/googletest/googletest/src/gtest-test-part.cc
build obj/third_party/googletest/googletest/googletest/src/googletest.gtest-typed-test.o: cxx ../../OrginPackage/crashpad-main/third_party/googletest/googletest/googletest/src/gtest-typed-test.cc
build obj/third_party/googletest/googletest/googletest/src/googletest.gtest.o: cxx ../../OrginPackage/crashpad-main/third_party/googletest/googletest/googletest/src/gtest.cc

build obj/third_party/googletest/libgoogletest.a: alink obj/third_party/googletest/googletest/googletest/src/googletest.gtest-assertion-result.o obj/third_party/googletest/googletest/googletest/src/googletest.gtest-death-test.o obj/third_party/googletest/googletest/googletest/src/googletest.gtest-filepath.o obj/third_party/googletest/googletest/googletest/src/googletest.gtest-matchers.o obj/third_party/googletest/googletest/googletest/src/googletest.gtest-port.o obj/third_party/googletest/googletest/googletest/src/googletest.gtest-printers.o obj/third_party/googletest/googletest/googletest/src/googletest.gtest-test-part.o obj/third_party/googletest/googletest/googletest/src/googletest.gtest-typed-test.o obj/third_party/googletest/googletest/googletest/src/googletest.gtest.o
  arflags =
  output_extension = .a
  output_dir = obj/third_party/googletest
