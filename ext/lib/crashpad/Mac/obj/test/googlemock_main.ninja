defines = -DCRASHPAD_TEST_LAUNCHER_GOOGLEMOCK -DNDEBUG
framework_dirs =
include_dirs = -I../../OrginPackage/crashpad-main -Igen -I../../OrginPackage/crashpad-main/third_party/mini_chromium/mini_chromium -I../../OrginPackage/crashpad-main/third_party/googletest/googletest/googletest/include -I../../OrginPackage/crashpad-main/third_party/googletest/googletest/googlemock/include
cflags = -Wall -Werror -Wextra -fno-exceptions -fno-rtti -fno-strict-aliasing -fobjc-call-cxx-cdtors -fstack-protector-all -fvisibility-inlines-hidden -fvisibility=hidden -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk -arch arm64 -mmacosx-version-min=12.0 -O3 -Wexit-time-destructors -Wimplicit-fallthrough
cflags_cc = -std=c++23
label_name = googlemock_main
target_output_name = libgooglemock_main

build obj/test/googlemock_main.gtest_main.o: cxx ../../OrginPackage/crashpad-main/test/gtest_main.cc || obj/util/mig.stamp

build obj/test/libgooglemock_main.a: alink obj/test/googlemock_main.gtest_main.o || obj/test/libtest.a obj/third_party/mini_chromium/base.stamp obj/third_party/mini_chromium/base_test_support.stamp obj/third_party/googletest/libgoogletest.a obj/third_party/googletest/libgooglemock.a obj/third_party/mini_chromium/mini_chromium/base/libbase.a obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/util/no_cfi_icall.stamp obj/util/libutil.a obj/third_party/zlib/zlib.stamp obj/util/libmig_output.a obj/handler/libhandler.a obj/handler/libcommon.a obj/client/libcommon.a obj/minidump/libminidump.a obj/minidump/libformat.a obj/snapshot/libcontext.a obj/snapshot/libsnapshot.a obj/util/libnet.a obj/client/libclient.a obj/tools/tool_support.stamp
  arflags =
  output_extension = .a
  output_dir = obj/test
