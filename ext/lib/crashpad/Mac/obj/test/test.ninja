defines = -DNDEBUG -DCRASHPAD_ZLIB_SOURCE_SYSTEM
framework_dirs =
include_dirs = -I../../OrginPackage/crashpad-main -Igen -I../../OrginPackage/crashpad-main/third_party/mini_chromium/mini_chromium -I../../OrginPackage/crashpad-main/compat/mac -I../../OrginPackage/crashpad-main/compat/non_win -I../../OrginPackage/crashpad-main/third_party/googletest/googletest/googletest/include
cflags = -Wall -Werror -Wextra -fno-exceptions -fno-rtti -fno-strict-aliasing -fobjc-call-cxx-cdtors -fstack-protector-all -fvisibility-inlines-hidden -fvisibility=hidden -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk -arch arm64 -mmacosx-version-min=12.0 -O3 -Wexit-time-destructors -Wimplicit-fallthrough
cflags_cc = -std=c++23
label_name = test
target_output_name = libtest

build obj/test/test.errors.o: cxx ../../OrginPackage/crashpad-main/test/errors.cc || obj/util/mig.stamp
build obj/test/test.file.o: cxx ../../OrginPackage/crashpad-main/test/file.cc || obj/util/mig.stamp
build obj/test/test.filesystem.o: cxx ../../OrginPackage/crashpad-main/test/filesystem.cc || obj/util/mig.stamp
build obj/test/test.hex_string.o: cxx ../../OrginPackage/crashpad-main/test/hex_string.cc || obj/util/mig.stamp
build obj/test/test.main_arguments.o: cxx ../../OrginPackage/crashpad-main/test/main_arguments.cc || obj/util/mig.stamp
build obj/test/test.multiprocess_exec.o: cxx ../../OrginPackage/crashpad-main/test/multiprocess_exec.cc || obj/util/mig.stamp
build obj/test/test.process_type.o: cxx ../../OrginPackage/crashpad-main/test/process_type.cc || obj/util/mig.stamp
build obj/test/test.scoped_module_handle.o: cxx ../../OrginPackage/crashpad-main/test/scoped_module_handle.cc || obj/util/mig.stamp
build obj/test/test.scoped_temp_dir.o: cxx ../../OrginPackage/crashpad-main/test/scoped_temp_dir.cc || obj/util/mig.stamp
build obj/test/test.test_paths.o: cxx ../../OrginPackage/crashpad-main/test/test_paths.cc || obj/util/mig.stamp
build obj/test/test.scoped_guarded_page_posix.o: cxx ../../OrginPackage/crashpad-main/test/scoped_guarded_page_posix.cc || obj/util/mig.stamp
build obj/test/test.scoped_temp_dir_posix.o: cxx ../../OrginPackage/crashpad-main/test/scoped_temp_dir_posix.cc || obj/util/mig.stamp
build obj/test/test.multiprocess_exec_posix.o: cxx ../../OrginPackage/crashpad-main/test/multiprocess_exec_posix.cc || obj/util/mig.stamp
build obj/test/test.multiprocess_posix.o: cxx ../../OrginPackage/crashpad-main/test/multiprocess_posix.cc || obj/util/mig.stamp
build obj/test/test.scoped_set_thread_name_posix.o: cxx ../../OrginPackage/crashpad-main/test/scoped_set_thread_name_posix.cc || obj/util/mig.stamp
build obj/test/mac/test.mach_errors.o: cxx ../../OrginPackage/crashpad-main/test/mac/mach_errors.cc || obj/util/mig.stamp
build obj/test/mac/test.dyld.o: cxx ../../OrginPackage/crashpad-main/test/mac/dyld.cc || obj/util/mig.stamp
build obj/test/mac/test.exception_swallower.o: cxx ../../OrginPackage/crashpad-main/test/mac/exception_swallower.cc || obj/util/mig.stamp
build obj/test/mac/test.mach_multiprocess.o: cxx ../../OrginPackage/crashpad-main/test/mac/mach_multiprocess.cc || obj/util/mig.stamp

build obj/test/libtest.a: alink obj/test/test.errors.o obj/test/test.file.o obj/test/test.filesystem.o obj/test/test.hex_string.o obj/test/test.main_arguments.o obj/test/test.multiprocess_exec.o obj/test/test.process_type.o obj/test/test.scoped_module_handle.o obj/test/test.scoped_temp_dir.o obj/test/test.test_paths.o obj/test/test.scoped_guarded_page_posix.o obj/test/test.scoped_temp_dir_posix.o obj/test/test.multiprocess_exec_posix.o obj/test/test.multiprocess_posix.o obj/test/test.scoped_set_thread_name_posix.o obj/test/mac/test.mach_errors.o obj/test/mac/test.dyld.o obj/test/mac/test.exception_swallower.o obj/test/mac/test.mach_multiprocess.o || obj/third_party/mini_chromium/base.stamp obj/compat/compat.stamp obj/third_party/googletest/libgoogletest.a obj/util/libutil.a obj/handler/libhandler.a obj/snapshot/libsnapshot.a obj/third_party/mini_chromium/mini_chromium/base/libbase.a obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/util/no_cfi_icall.stamp obj/third_party/zlib/zlib.stamp obj/util/libmig_output.a obj/handler/libcommon.a obj/client/libcommon.a obj/minidump/libminidump.a obj/minidump/libformat.a obj/snapshot/libcontext.a obj/util/libnet.a obj/client/libclient.a obj/tools/tool_support.stamp
  arflags =
  output_extension = .a
  output_dir = obj/test
