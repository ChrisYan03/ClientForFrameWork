build obj/test/test_test.scoped_temp_dir_test.o: cxx ../../OrginPackage/crashpad-main/test/scoped_temp_dir_test.cc || obj/util/mig.stamp
build obj/test/test_test.test_paths_test.o: cxx ../../OrginPackage/crashpad-main/test/test_paths_test.cc || obj/util/mig.stamp
build obj/test/test_test.multiprocess_posix_test.o: cxx ../../OrginPackage/crashpad-main/test/multiprocess_posix_test.cc || obj/util/mig.stamp
build obj/test/mac/test_test.mach_multiprocess_test.o: cxx ../../OrginPackage/crashpad-main/test/mac/mach_multiprocess_test.cc || obj/util/mig.stamp

build obj/test/test_test.stamp: stamp obj/test/test_test.hex_string_test.o obj/test/test_test.main_arguments_test.o obj/test/test_test.multiprocess_exec_test.o obj/test/test_test.scoped_guarded_page_test.o obj/test/test_test.scoped_temp_dir_test.o obj/test/test_test.test_paths_test.o obj/test/test_test.multiprocess_posix_test.o obj/test/mac/test_test.mach_multiprocess_test.o || obj/test/libtest.a obj/third_party/mini_chromium/base.stamp obj/compat/compat.stamp obj/third_party/googletest/libgoogletest.a obj/third_party/googletest/libgooglemock.a obj/util/libutil.a obj/third_party/mini_chromium/mini_chromium/base/libbase.a obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/util/no_cfi_icall.stamp obj/third_party/zlib/zlib.stamp obj/util/libmig_output.a obj/handler/libhandler.a obj/handler/libcommon.a obj/client/libcommon.a obj/minidump/libminidump.a obj/minidump/libformat.a obj/snapshot/libcontext.a obj/snapshot/libsnapshot.a obj/util/libnet.a obj/client/libclient.a obj/tools/tool_support.stamp ./crashpad_test_test_multiprocess_exec_test_child
