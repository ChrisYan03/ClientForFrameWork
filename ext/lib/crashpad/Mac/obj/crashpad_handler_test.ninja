defines = -DNDEBUG
framework_dirs =
include_dirs =
label_name = crashpad_handler_test
target_output_name = crashpad_handler_test


build ./crashpad_handler_test: link obj/handler/handler_test.crash_report_upload_rate_limit_test.o obj/handler/handler_test.minidump_to_upload_parameters_test.o obj/tools/tool_support.tool_support.o obj/test/libgoogletest_main.a obj/handler/libhandler.a obj/handler/libcommon.a obj/third_party/mini_chromium/mini_chromium/base/libbase.a obj/util/libutil.a obj/util/libmig_output.a obj/client/libcommon.a obj/minidump/libminidump.a obj/minidump/libformat.a obj/snapshot/libcontext.a obj/snapshot/libsnapshot.a obj/util/libnet.a obj/client/libclient.a obj/snapshot/libtest_support.a obj/test/libtest.a obj/third_party/googletest/libgoogletest.a || obj/handler/handler_test.stamp obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/util/no_cfi_icall.stamp obj/third_party/zlib/zlib.stamp obj/tools/tool_support.stamp
  ldflags = -isysroot /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk -arch arm64 -mmacosx-version-min=12.0 -Wl,-dead_strip
  libs = -lbsm -lz
  frameworks = -framework CoreFoundation -framework Foundation -framework Security -framework ApplicationServices -framework IOKit
  swiftmodules =
  output_extension = 
  output_dir = .
