rule cc
  command = clang -MMD -MF ${out}.d ${defines} ${include_dirs} ${framework_dirs} ${cflags} ${cflags_c} -c ${in} -o ${out}
  description = CC ${out}
  depfile = ${out}.d
  deps = gcc
rule cxx
  command = clang++ -MMD -MF ${out}.d ${defines} ${include_dirs} ${framework_dirs} ${cflags} ${cflags_cc} -c ${in} -o ${out}
  description = CXX ${out}
  depfile = ${out}.d
  deps = gcc
rule objc
  command = clang -MMD -MF ${out}.d ${defines} ${include_dirs} ${framework_dirs} ${cflags} ${cflags_objc} -c ${in} -o ${out}
  description = OBJC ${out}
  depfile = ${out}.d
  deps = gcc
rule objcxx
  command = clang++ -MMD -MF ${out}.d ${defines} ${include_dirs} ${framework_dirs} ${cflags} ${cflags_objcc} -c ${in} -o ${out}
  description = OBJCXX ${out}
  depfile = ${out}.d
  deps = gcc
rule asm
  command = clang++ -MMD -MF ${out}.d ${defines} ${include_dirs} ${asmflags} -c ${in} -o ${out}
  description = ASM ${out}
  depfile = ${out}.d
  deps = gcc
rule alink
  command = libtool -static -no_warning_for_no_symbols ${arflags} -o ${out} ${in}
  description = AR ${out}
rule solink_module
  command = clang++ -shared ${ldflags} -o "${output_dir}/${target_output_name}${output_extension}" -Wl,-install_name,"${target_output_name}${output_extension}"  ${in} ${solibs} ${frameworks}  ${libs}
  description = SOLINK_MODULE ${output_dir}/${target_output_name}${output_extension}
rule link
  command = clang++ ${ldflags} -o "${output_dir}/${target_output_name}${output_extension}"  ${in} ${solibs} ${frameworks}  ${libs}
  description = LINK ${output_dir}/${target_output_name}${output_extension}
rule copy
  command = ln -f ${in} ${out} 2>/dev/null || (rm -rf ${out} && cp -af ${in} ${out})
  description = COPY ${in} ${out}
rule stamp
  command = touch ${out}
  description = STAMP ${out}
rule copy_bundle_data
  command = rm -rf ${out} && cp -fRc ${in} ${out} 2>/dev/null || (rm -rf ${out} && cp -fR ${in} ${out})
  description = COPY_BUNDLE_DATA ${in} ${out}
rule compile_xcassets
  command = /bin/true

