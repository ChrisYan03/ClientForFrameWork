defines = -DCRASHPAD_INFO_SIZE_TEST_MODULE_SMALL -DNDEBUG
include_dirs = -I../../third_party/mini_chromium/mini_chromium -Igen
cflags = /DNOMINMAX /DUNICODE /DWIN32_LEAN_AND_MEAN /D_CRT_SECURE_NO_WARNINGS /D_HAS_EXCEPTIONS=0 /D_UNICODE /FS /W4 /WX /Zi /bigobj /wd4996 --target=x86_64-pc-windows -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -Wno-cast-function-type-mismatch -Wno-format -Wno-microsoft-cast -Wno-missing-field-initializers -Wno-sign-compare -Wno-unused-const-variable -Wno-unused-function /O2 /Ob2 /Oy- /Zc$:inline -Wexit-time-destructors -Wimplicit-fallthrough
cflags_cc = /std$:c++23preview
label_name = crashpad_snapshot_test_module_small
target_out_dir = obj/snapshot
target_output_name = crashpad_snapshot_test_module_small

build obj/snapshot/crashpad_snapshot_test_module_small.crashpad_info_size_test_module.obj: cxx ../../snapshot/crashpad_info_size_test_module.cc
  source_file_part = crashpad_info_size_test_module.cc
  source_name_part = crashpad_info_size_test_module

build ./crashpad_snapshot_test_module_small.dll: solink_module obj/snapshot/crashpad_snapshot_test_module_small.crashpad_info_size_test_module.obj obj/third_party/mini_chromium/mini_chromium/base/base.lib || obj/third_party/mini_chromium/base.stamp obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp
  ldflags = /DEBUG /OPT$:ICF /OPT$:REF
  libs = kernel32.lib advapi32.lib
  frameworks =
  swiftmodules =
  output_extension = .dll
  output_dir = .
