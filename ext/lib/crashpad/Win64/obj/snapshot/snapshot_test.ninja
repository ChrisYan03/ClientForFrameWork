build obj/snapshot/snapshot_test.stamp: stamp obj/snapshot/snapshot_test.cpu_context_test.obj obj/snapshot/snapshot_test.memory_snapshot_test.obj obj/snapshot/minidump/snapshot_test.process_snapshot_minidump_test.obj obj/snapshot/snapshot_test.crashpad_info_client_options_test.obj obj/snapshot/crashpad_types/snapshot_test.crashpad_info_reader_test.obj obj/snapshot/win/snapshot_test.cpu_context_win_test.obj obj/snapshot/win/snapshot_test.exception_snapshot_win_test.obj obj/snapshot/win/snapshot_test.extra_memory_ranges_test.obj obj/snapshot/win/snapshot_test.module_snapshot_win_test.obj obj/snapshot/win/snapshot_test.pe_image_reader_test.obj obj/snapshot/win/snapshot_test.process_reader_win_test.obj obj/snapshot/win/snapshot_test.process_snapshot_win_test.obj obj/snapshot/win/snapshot_test.system_snapshot_win_test.obj || obj/snapshot/test_support.lib obj/third_party/mini_chromium/base.stamp obj/client/common.lib obj/compat/compat.lib obj/minidump/format.lib obj/test/test.lib obj/third_party/googletest/googletest.lib obj/third_party/googletest/googlemock.lib obj/util/util.lib obj/snapshot/snapshot.lib obj/snapshot/context.lib obj/third_party/mini_chromium/mini_chromium/base/base.lib obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/util/no_cfi_icall.stamp obj/third_party/getopt/getopt.lib obj/third_party/zlib/zlib.lib ./crashpad_snapshot_test_module.dll ./crashpad_snapshot_test_module_large.dll ./crashpad_snapshot_test_module_small.dll ./crashpad_snapshot_test_annotations.exe ./crashpad_snapshot_test_crashing_child.exe ./crashpad_snapshot_test_dump_without_crashing.exe ./crashpad_snapshot_test_extra_memory_ranges.exe ./crashpad_snapshot_test_image_reader.exe ./crashpad_snapshot_test_image_reader_module.dll
