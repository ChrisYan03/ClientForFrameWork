defines = -DNDEBUG
include_dirs =
cflags = /DNOMINMAX /DUNICODE /DWIN32_LEAN_AND_MEAN /D_CRT_SECURE_NO_WARNINGS /D_HAS_EXCEPTIONS=0 /D_UNICODE /FS /W4 /WX /Zi /bigobj /wd4996 --target=x86_64-pc-windows -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -Wno-cast-function-type-mismatch -Wno-format -Wno-microsoft-cast -Wno-missing-field-initializers -Wno-sign-compare -Wno-unused-const-variable -Wno-unused-function /O2 /Ob2 /Oy- /Zc$:inline -Wexit-time-destructors -Wimplicit-fallthrough
cflags_cc = /std$:c++23preview
label_name = crashpad_util_test_process_info_test_child
target_out_dir = obj/util
target_output_name = crashpad_util_test_process_info_test_child

build obj/util/win/crashpad_util_test_process_info_test_child.process_info_test_child.obj: cxx ../../util/win/process_info_test_child.cc
  source_file_part = process_info_test_child.cc
  source_name_part = process_info_test_child

build ./crashpad_util_test_process_info_test_child.exe: link obj/util/win/crashpad_util_test_process_info_test_child.process_info_test_child.obj
  ldflags = /DEBUG /OPT$:ICF /OPT$:REF /SUBSYSTEM$:CONSOLE
  libs = kernel32.lib
  frameworks =
  swiftmodules =
  output_extension = .exe
  output_dir = .
