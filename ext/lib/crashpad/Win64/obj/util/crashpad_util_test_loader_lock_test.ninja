defines = -DNDEBUG -DCRASHPAD_ZLIB_SOURCE_EMBEDDED
include_dirs = -I../.. -Igen -I../../third_party/mini_chromium/mini_chromium -I../../compat/win -I../../third_party/zlib/zlib
cflags = /DNOMINMAX /DUNICODE /DWIN32_LEAN_AND_MEAN /D_CRT_SECURE_NO_WARNINGS /D_HAS_EXCEPTIONS=0 /D_UNICODE /FS /W4 /WX /Zi /bigobj /wd4996 --target=x86_64-pc-windows -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -Wno-cast-function-type-mismatch -Wno-format -Wno-microsoft-cast -Wno-missing-field-initializers -Wno-sign-compare -Wno-unused-const-variable -Wno-unused-function /O2 /Ob2 /Oy- /Zc$:inline -Wexit-time-destructors -Wimplicit-fallthrough
cflags_cc = /std$:c++23preview
label_name = crashpad_util_test_loader_lock_test
target_out_dir = obj/util
target_output_name = crashpad_util_test_loader_lock_test

build obj/util/win/crashpad_util_test_loader_lock_test.loader_lock_test_dll.obj: cxx ../../util/win/loader_lock_test_dll.cc
  source_file_part = loader_lock_test_dll.cc
  source_name_part = loader_lock_test_dll

build ./crashpad_util_test_loader_lock_test.dll: solink_module obj/util/win/crashpad_util_test_loader_lock_test.loader_lock_test_dll.obj obj/util/util.lib obj/third_party/mini_chromium/mini_chromium/base/base.lib obj/compat/compat.lib obj/third_party/getopt/getopt.lib obj/third_party/zlib/zlib.lib || obj/util/no_cfi_icall.stamp obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp
  ldflags = /DEBUG /OPT$:ICF /OPT$:REF
  libs = kernel32.lib user32.lib version.lib winhttp.lib advapi32.lib
  frameworks =
  swiftmodules =
  output_extension = .dll
  output_dir = .
