build obj/third_party/googletest/googletest/googlemock/src/googlemock.gmock-spec-builders.obj: cxx ../../third_party/googletest/googletest/googlemock/src/gmock-spec-builders.cc
  source_file_part = gmock-spec-builders.cc
  source_name_part = gmock-spec-builders
build obj/third_party/googletest/googletest/googlemock/src/googlemock.gmock.obj: cxx ../../third_party/googletest/googletest/googlemock/src/gmock.cc
  source_file_part = gmock.cc
  source_name_part = gmock

build obj/third_party/googletest/googlemock.lib: alink obj/third_party/googletest/googletest/googlemock/src/googlemock.gmock-cardinalities.obj obj/third_party/googletest/googletest/googlemock/src/googlemock.gmock-internal-utils.obj obj/third_party/googletest/googletest/googlemock/src/googlemock.gmock-matchers.obj obj/third_party/googletest/googletest/googlemock/src/googlemock.gmock-spec-builders.obj obj/third_party/googletest/googletest/googlemock/src/googlemock.gmock.obj || obj/third_party/googletest/googletest.lib
  arflags =
  output_extension = .lib
  output_dir = obj/third_party/googletest
