build ./gmock_link_test.exe: link obj/third_party/googletest/googletest/googlemock/test/gmock_link_test.gmock_link2_test.obj obj/third_party/googletest/googletest/googlemock/test/gmock_link_test.gmock_link_test.obj obj/third_party/googletest/googlemock.lib obj/third_party/googletest/googlemock_main.lib obj/third_party/googletest/googletest.lib
