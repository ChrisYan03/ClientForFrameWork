build obj/third_party/googletest/googletest/googlemock/test/gmock_link_test.gmock_link2_test.obj: cxx ../../third_party/googletest/googletest/googlemock/test/gmock_link2_test.cc
  source_file_part = gmock_link2_test.cc
  source_name_part = gmock_link2_test
build obj/third_party/googletest/googletest/googlemock/test/gmock_link_test.gmock_link_test.obj: cxx ../../third_party/googletest/googletest/googlemock/test/gmock_link_test.cc
  source_file_part = gmock_link_test.cc
