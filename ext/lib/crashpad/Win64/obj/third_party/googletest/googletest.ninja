defines = -DNDEBUG -DGUNIT_NO_GOOGLE3=1
include_dirs = -I../../third_party/googletest/googletest/googletest -I../../third_party/googletest/googletest/googletest/include
cflags = /DNOMINMAX /DUNICODE /DWIN32_LEAN_AND_MEAN /D_CRT_SECURE_NO_WARNINGS /D_HAS_EXCEPTIONS=0 /D_UNICODE /FS /W4 /WX /Zi /bigobj /wd4996 --target=x86_64-pc-windows -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -Wno-cast-function-type-mismatch -Wno-format -Wno-microsoft-cast -Wno-missing-field-initializers -Wno-sign-compare -Wno-unused-const-variable -Wno-unused-function /O2 /Ob2 /Oy- /Zc$:inline -Wimplicit-fallthrough
cflags_cc = /std$:c++23preview
label_name = googletest
target_out_dir = obj/third_party/googletest
target_output_name = googletest

build obj/third_party/googletest/googletest/googletest/src/googletest.gtest-assertion-result.obj: cxx ../../third_party/googletest/googletest/googletest/src/gtest-assertion-result.cc
  source_file_part = gtest-assertion-result.cc
  source_name_part = gtest-assertion-result
build obj/third_party/googletest/googletest/googletest/src/googletest.gtest-death-test.obj: cxx ../../third_party/googletest/googletest/googletest/src/gtest-death-test.cc
  source_file_part = gtest-death-test.cc
  source_name_part = gtest-death-test
build obj/third_party/googletest/googletest/googletest/src/googletest.gtest-filepath.obj: cxx ../../third_party/googletest/googletest/googletest/src/gtest-filepath.cc
  source_file_part = gtest-filepath.cc
  source_name_part = gtest-filepath
build obj/third_party/googletest/googletest/googletest/src/googletest.gtest-matchers.obj: cxx ../../third_party/googletest/googletest/googletest/src/gtest-matchers.cc
  source_file_part = gtest-matchers.cc
  source_name_part = gtest-matchers
build obj/third_party/googletest/googletest/googletest/src/googletest.gtest-port.obj: cxx ../../third_party/googletest/googletest/googletest/src/gtest-port.cc
  source_file_part = gtest-port.cc
