build obj/third_party/googletest/googletest/googletest/src/googletest.gtest-test-part.obj: cxx ../../third_party/googletest/googletest/googletest/src/gtest-test-part.cc
  source_file_part = gtest-test-part.cc
  source_name_part = gtest-test-part
build obj/third_party/googletest/googletest/googletest/src/googletest.gtest-typed-test.obj: cxx ../../third_party/googletest/googletest/googletest/src/gtest-typed-test.cc
  source_file_part = gtest-typed-test.cc
  source_name_part = gtest-typed-test
build obj/third_party/googletest/googletest/googletest/src/googletest.gtest.obj: cxx ../../third_party/googletest/googletest/googletest/src/gtest.cc
  source_file_part = gtest.cc
  source_name_part = gtest

build obj/third_party/googletest/googletest.lib: alink obj/third_party/googletest/googletest/googletest/src/googletest.gtest-assertion-result.obj obj/third_party/googletest/googletest/googletest/src/googletest.gtest-death-test.obj obj/third_party/googletest/googletest/googletest/src/googletest.gtest-filepath.obj obj/third_party/googletest/googletest/googletest/src/googletest.gtest-matchers.obj obj/third_party/googletest/googletest/googletest/src/googletest.gtest-port.obj obj/third_party/googletest/googletest/googletest/src/googletest.gtest-printers.obj obj/third_party/googletest/googletest/googletest/src/googletest.gtest-test-part.obj obj/third_party/googletest/googletest/googletest/src/googletest.gtest-typed-test.obj obj/third_party/googletest/googletest/googletest/src/googletest.gtest.obj
  arflags =
  output_extension = .lib
  output_dir = obj/third_party/googletest
