defines = -DHAVE_STDARG_H -DNDEBUG -DCRASHPAD_ZLIB_SOURCE_EMBEDDED
include_dirs = -I../../third_party/zlib/zlib
cflags = /wd4131 /wd4244 /wd4245 /wd4267 /wd4324 /wd4702 -msse4.2 -mpclmul -Wno-incompatible-pointer-types /DNOMINMAX /DUNICODE /DWIN32_LEAN_AND_MEAN /D_CRT_SECURE_NO_WARNINGS /D_HAS_EXCEPTIONS=0 /D_UNICODE /FS /W4 /WX /Zi /bigobj /wd4996 --target=x86_64-pc-windows -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -Wno-cast-function-type-mismatch -Wno-format -Wno-microsoft-cast -Wno-missing-field-initializers -Wno-sign-compare -Wno-unused-const-variable -Wno-unused-function /O2 /Ob2 /Oy- /Zc$:inline -Wexit-time-destructors
cflags_c =
label_name = zlib
target_out_dir = obj/third_party/zlib
target_output_name = zlib

build obj/third_party/zlib/zlib/zlib.adler32.obj: cc ../../third_party/zlib/zlib/adler32.c
  source_file_part = adler32.c
  source_name_part = adler32
build obj/third_party/zlib/zlib/zlib.compress.obj: cc ../../third_party/zlib/zlib/compress.c
  source_file_part = compress.c
  source_name_part = compress
build obj/third_party/zlib/zlib/zlib.crc32.obj: cc ../../third_party/zlib/zlib/crc32.c
  source_file_part = crc32.c
  source_name_part = crc32
build obj/third_party/zlib/zlib/zlib.deflate.obj: cc ../../third_party/zlib/zlib/deflate.c
  source_file_part = deflate.c
  source_name_part = deflate
build obj/third_party/zlib/zlib/zlib.gzclose.obj: cc ../../third_party/zlib/zlib/gzclose.c
  source_file_part = gzclose.c
  source_name_part = gzclose
build obj/third_party/zlib/zlib/zlib.gzlib.obj: cc ../../third_party/zlib/zlib/gzlib.c
  source_file_part = gzlib.c
  source_name_part = gzlib
build obj/third_party/zlib/zlib/zlib.gzread.obj: cc ../../third_party/zlib/zlib/gzread.c
  source_file_part = gzread.c
  source_name_part = gzread
build obj/third_party/zlib/zlib/zlib.gzwrite.obj: cc ../../third_party/zlib/zlib/gzwrite.c
  source_file_part = gzwrite.c
  source_name_part = gzwrite
build obj/third_party/zlib/zlib/zlib.infback.obj: cc ../../third_party/zlib/zlib/infback.c
  source_file_part = infback.c
  source_name_part = infback
build obj/third_party/zlib/zlib/zlib.inffast.obj: cc ../../third_party/zlib/zlib/inffast.c
  source_file_part = inffast.c
  source_name_part = inffast
build obj/third_party/zlib/zlib/zlib.inflate.obj: cc ../../third_party/zlib/zlib/inflate.c
  source_file_part = inflate.c
  source_name_part = inflate
build obj/third_party/zlib/zlib/zlib.inftrees.obj: cc ../../third_party/zlib/zlib/inftrees.c
  source_file_part = inftrees.c
  source_name_part = inftrees
build obj/third_party/zlib/zlib/zlib.trees.obj: cc ../../third_party/zlib/zlib/trees.c
  source_file_part = trees.c
  source_name_part = trees
build obj/third_party/zlib/zlib/zlib.uncompr.obj: cc ../../third_party/zlib/zlib/uncompr.c
  source_file_part = uncompr.c
  source_name_part = uncompr
build obj/third_party/zlib/zlib/zlib.zutil.obj: cc ../../third_party/zlib/zlib/zutil.c
  source_file_part = zutil.c
  source_name_part = zutil
build obj/third_party/zlib/zlib/zlib.crc_folding.obj: cc ../../third_party/zlib/zlib/crc_folding.c
  source_file_part = crc_folding.c
  source_name_part = crc_folding

build obj/third_party/zlib/zlib.lib: alink obj/third_party/zlib/zlib/zlib.adler32.obj obj/third_party/zlib/zlib/zlib.compress.obj obj/third_party/zlib/zlib/zlib.crc32.obj obj/third_party/zlib/zlib/zlib.deflate.obj obj/third_party/zlib/zlib/zlib.gzclose.obj obj/third_party/zlib/zlib/zlib.gzlib.obj obj/third_party/zlib/zlib/zlib.gzread.obj obj/third_party/zlib/zlib/zlib.gzwrite.obj obj/third_party/zlib/zlib/zlib.infback.obj obj/third_party/zlib/zlib/zlib.inffast.obj obj/third_party/zlib/zlib/zlib.inflate.obj obj/third_party/zlib/zlib/zlib.inftrees.obj obj/third_party/zlib/zlib/zlib.trees.obj obj/third_party/zlib/zlib/zlib.uncompr.obj obj/third_party/zlib/zlib/zlib.zutil.obj obj/third_party/zlib/zlib/zlib.crc_folding.obj
  arflags =
  output_extension = .lib
  output_dir = obj/third_party/zlib
