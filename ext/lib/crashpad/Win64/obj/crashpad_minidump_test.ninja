ni_chromium/mini_chromium/build/buildflag_header_h.stamp
  ldflags = /DEBUG /OPT$:ICF /OPT$:REF /SUBSYSTEM$:CONSOLE
  libs = kernel32.lib advapi32.lib user32.lib version.lib winhttp.lib powrprof.lib shell32.lib
