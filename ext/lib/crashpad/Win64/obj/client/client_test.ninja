build obj/client/client_test.stamp: stamp obj/client/client_test.annotation_list_test.obj obj/client/client_test.annotation_test.obj obj/client/client_test.crash_report_database_test.obj obj/client/client_test.crashpad_info_test.obj obj/client/client_test.length_delimited_ring_buffer_test.obj obj/client/client_test.prune_crash_reports_test.obj obj/client/client_test.ring_buffer_annotation_test.obj obj/client/client_test.settings_test.obj obj/client/client_test.simple_address_range_bag_test.obj obj/client/client_test.simple_string_dictionary_test.obj obj/client/client_test.crashpad_client_win_test.obj || obj/client/client.lib obj/third_party/mini_chromium/base.stamp obj/compat/compat.lib obj/snapshot/snapshot.lib obj/test/test.lib obj/third_party/googletest/googletest.lib obj/third_party/googletest/googlemock.lib obj/util/util.lib obj/client/common.lib obj/third_party/mini_chromium/mini_chromium/base/base.lib obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/util/no_cfi_icall.stamp obj/third_party/getopt/getopt.lib obj/third_party/zlib/zlib.lib obj/snapshot/context.lib obj/minidump/format.lib ./crashpad_handler.exe obj/handler/crashpad_handler_console.stamp obj/handler/win/wer/crashpad_wer_handler.stamp
