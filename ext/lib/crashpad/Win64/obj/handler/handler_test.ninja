defines = -DNDEBUG -DCRASHPAD_ZLIB_SOURCE_EMBEDDED
include_dirs = -I../.. -Igen -I../../third_party/mini_chromium/mini_chromium -I../../compat/win -I../../third_party/zlib/zlib -I../../third_party/googletest/googletest/googletest/include
cflags = /DNOMINMAX /DUNICODE /DWIN32_LEAN_AND_MEAN /D_CRT_SECURE_NO_WARNINGS /D_HAS_EXCEPTIONS=0 /D_UNICODE /FS /W4 /WX /Zi /bigobj /wd4996 --target=x86_64-pc-windows -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -Wno-cast-function-type-mismatch -Wno-format -Wno-microsoft-cast -Wno-missing-field-initializers -Wno-sign-compare -Wno-unused-const-variable -Wno-unused-function /O2 /Ob2 /Oy- /Zc$:inline -Wexit-time-destructors -Wimplicit-fallthrough
cflags_cc = /std$:c++23preview
label_name = handler_test
target_out_dir = obj/handler
target_output_name = handler_test

build obj/handler/handler_test.crash_report_upload_rate_limit_test.obj: cxx ../../handler/crash_report_upload_rate_limit_test.cc
  source_file_part = crash_report_upload_rate_limit_test.cc
  source_name_part = crash_report_upload_rate_limit_test
build obj/handler/handler_test.minidump_to_upload_parameters_test.obj: cxx ../../handler/minidump_to_upload_parameters_test.cc
  source_file_part = minidump_to_upload_parameters_test.cc
  source_name_part = minidump_to_upload_parameters_test
build obj/handler/handler_test.crashpad_handler_test.obj: cxx ../../handler/crashpad_handler_test.cc
  source_file_part = crashpad_handler_test.cc
  source_name_part = crashpad_handler_test

build obj/handler/handler_test.stamp: stamp obj/handler/handler_test.crash_report_upload_rate_limit_test.obj obj/handler/handler_test.minidump_to_upload_parameters_test.obj obj/handler/handler_test.crashpad_handler_test.obj || obj/handler/handler.lib obj/client/client.lib obj/compat/compat.lib obj/snapshot/snapshot.lib obj/snapshot/test_support.lib obj/test/test.lib obj/third_party/googletest/googletest.lib obj/third_party/mini_chromium/base.stamp obj/util/util.lib obj/minidump/test_support.lib obj/handler/win/wer/crashpad_wer_test.stamp obj/handler/common.lib obj/third_party/mini_chromium/mini_chromium/base/base.lib obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/util/no_cfi_icall.stamp obj/third_party/getopt/getopt.lib obj/third_party/zlib/zlib.lib obj/client/common.lib obj/minidump/minidump.lib obj/minidump/format.lib obj/snapshot/context.lib obj/util/net.lib obj/tools/tool_support.stamp obj/handler/win/wer/crashpad_wer_handler.stamp obj/util/util_registration_protocol.stamp ./crashpad_handler_test_extended_handler.exe ./fake_handler_that_crashes_at_startup.exe
