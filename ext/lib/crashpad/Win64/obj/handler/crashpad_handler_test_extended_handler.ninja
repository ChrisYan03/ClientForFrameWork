defines = -DNDEBUG -DCRASHPAD_ZLIB_SOURCE_EMBEDDED
include_dirs = -I../.. -Igen -I../../third_party/mini_chromium/mini_chromium -I../../compat/win -I../../third_party/zlib/zlib
cflags = /DNOMINMAX /DUNICODE /DWIN32_LEAN_AND_MEAN /D_CRT_SECURE_NO_WARNINGS /D_HAS_EXCEPTIONS=0 /D_UNICODE /FS /W4 /WX /Zi /bigobj /wd4996 --target=x86_64-pc-windows -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -Wno-cast-function-type-mismatch -Wno-format -Wno-microsoft-cast -Wno-missing-field-initializers -Wno-sign-compare -Wno-unused-const-variable -Wno-unused-function /O2 /Ob2 /Oy- /Zc$:inline -Wexit-time-destructors -Wimplicit-fallthrough
cflags_cc = /std$:c++23preview
label_name = crashpad_handler_test_extended_handler
target_out_dir = obj/handler
target_output_name = crashpad_handler_test_extended_handler

build obj/handler/crashpad_handler_test_extended_handler.crashpad_handler_test_extended_handler.obj: cxx ../../handler/crashpad_handler_test_extended_handler.cc
  source_file_part = crashpad_handler_test_extended_handler.cc
  source_name_part = crashpad_handler_test_extended_handler

build ./crashpad_handler_test_extended_handler.exe: link obj/handler/crashpad_handler_test_extended_handler.crashpad_handler_test_extended_handler.obj obj/tools/tool_support.tool_support.obj obj/handler/handler.lib obj/compat/compat.lib obj/minidump/test_support.lib obj/handler/common.lib obj/third_party/mini_chromium/mini_chromium/base/base.lib obj/util/util.lib obj/third_party/getopt/getopt.lib obj/third_party/zlib/zlib.lib obj/client/common.lib obj/minidump/minidump.lib obj/minidump/format.lib obj/snapshot/context.lib obj/snapshot/snapshot.lib obj/util/net.lib obj/client/client.lib obj/snapshot/test_support.lib obj/test/test.lib obj/third_party/googletest/googletest.lib || obj/build/default_exe_manifest_win.stamp obj/third_party/mini_chromium/base.stamp obj/tools/tool_support.stamp obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/util/no_cfi_icall.stamp
  ldflags = /DEBUG /OPT$:ICF /OPT$:REF /SUBSYSTEM$:CONSOLE
  libs = kernel32.lib advapi32.lib user32.lib version.lib winhttp.lib powrprof.lib rpcrt4.lib shell32.lib
  frameworks =
  swiftmodules =
  output_extension = .exe
  output_dir = .
