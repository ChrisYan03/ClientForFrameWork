defines = -DNDEBUG -DCRASHPAD_ZLIB_SOURCE_EMBEDDED
include_dirs = -I../.. -Igen -I../../third_party/mini_chromium/mini_chromium -I../../compat/win -I../../third_party/zlib/zlib -I../../third_party/googletest/googletest/googletest/include
cflags = /DNOMINMAX /DUNICODE /DWIN32_LEAN_AND_MEAN /D_CRT_SECURE_NO_WARNINGS /D_HAS_EXCEPTIONS=0 /D_UNICODE /FS /W4 /WX /Zi /bigobj /wd4996 --target=x86_64-pc-windows -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -Wno-cast-function-type-mismatch -Wno-format -Wno-microsoft-cast -Wno-missing-field-initializers -Wno-sign-compare -Wno-unused-const-variable -Wno-unused-function /O2 /Ob2 /Oy- /Zc$:inline -Wexit-time-destructors -Wimplicit-fallthrough
cflags_cc = /std$:c++23preview
label_name = crashpad_wer_test
target_out_dir = obj/handler/win/wer
target_output_name = crashpad_wer_test

build obj/handler/win/wer/crashpad_wer_test.crashpad_wer_module_unittest.obj: cxx ../../handler/win/wer/crashpad_wer_module_unittest.cc
  source_file_part = crashpad_wer_module_unittest.cc
  source_name_part = crashpad_wer_module_unittest

build obj/handler/win/wer/crashpad_wer_test.stamp: stamp obj/handler/win/wer/crashpad_wer_test.crashpad_wer_module_unittest.obj || ./crashpad_wer.dll obj/handler/win/wer/crashpad_wer_handler.stamp obj/client/client.lib obj/test/test.lib obj/third_party/googletest/googletest.lib obj/util/util_registration_protocol.stamp obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/client/common.lib obj/third_party/mini_chromium/mini_chromium/base/base.lib obj/util/util.lib obj/util/no_cfi_icall.stamp obj/compat/compat.lib obj/third_party/getopt/getopt.lib obj/third_party/zlib/zlib.lib
