defines = -DCRASHPAD_TEST_LAUNCHER_GOOGLETEST -DNDEBUG
include_dirs = -I../.. -Igen -I../../third_party/mini_chromium/mini_chromium -I../../third_party/googletest/googletest/googletest/include
cflags = /DNOMINMAX /DUNICODE /DWIN32_LEAN_AND_MEAN /D_CRT_SECURE_NO_WARNINGS /D_HAS_EXCEPTIONS=0 /D_UNICODE /FS /W4 /WX /Zi /bigobj /wd4996 --target=x86_64-pc-windows -Wendif-labels -Wextra-semi -Wheader-hygiene -Wnewline-eof -Wno-missing-field-initializers -Wno-unused-parameter -Wsign-compare -Wstring-conversion -Wvla -Wno-cast-function-type-mismatch -Wno-format -Wno-microsoft-cast -Wno-missing-field-initializers -Wno-sign-compare -Wno-unused-const-variable -Wno-unused-function /O2 /Ob2 /Oy- /Zc$:inline -Wexit-time-destructors -Wimplicit-fallthrough
cflags_cc = /std$:c++23preview
label_name = googletest_main
target_out_dir = obj/test
target_output_name = googletest_main

build obj/test/googletest_main.gtest_main.obj: cxx ../../test/gtest_main.cc
  source_file_part = gtest_main.cc
  source_name_part = gtest_main

build obj/test/googletest_main.lib: alink obj/test/googletest_main.gtest_main.obj || obj/test/test.lib obj/third_party/mini_chromium/base.stamp obj/third_party/mini_chromium/base_test_support.stamp obj/third_party/googletest/googletest.lib obj/third_party/mini_chromium/mini_chromium/base/base.lib obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/compat/compat.lib obj/util/no_cfi_icall.stamp obj/third_party/getopt/getopt.lib obj/util/util.lib obj/third_party/zlib/zlib.lib
  arflags =
  output_extension = .lib
  output_dir = obj/test
