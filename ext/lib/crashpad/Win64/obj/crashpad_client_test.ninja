defines = -DNDEBUG
include_dirs =
label_name = crashpad_client_test
target_out_dir = obj
target_output_name = crashpad_client_test


build ./crashpad_client_test.exe: link obj/client/client_test.annotation_list_test.obj obj/client/client_test.annotation_test.obj obj/client/client_test.crash_report_database_test.obj obj/client/client_test.crashpad_info_test.obj obj/client/client_test.length_delimited_ring_buffer_test.obj obj/client/client_test.prune_crash_reports_test.obj obj/client/client_test.ring_buffer_annotation_test.obj obj/client/client_test.settings_test.obj obj/client/client_test.simple_address_range_bag_test.obj obj/client/client_test.simple_string_dictionary_test.obj obj/client/client_test.crashpad_client_win_test.obj obj/test/googlemock_main.lib obj/client/client.lib obj/client/common.lib obj/third_party/mini_chromium/mini_chromium/base/base.lib obj/util/util.lib obj/compat/compat.lib obj/third_party/getopt/getopt.lib obj/third_party/zlib/zlib.lib obj/snapshot/snapshot.lib obj/snapshot/context.lib obj/minidump/format.lib obj/test/test.lib obj/third_party/googletest/googletest.lib obj/third_party/googletest/googlemock.lib || obj/client/client_test.stamp obj/third_party/mini_chromium/mini_chromium/build/build.stamp obj/third_party/mini_chromium/mini_chromium/build/buildflag_header_h.stamp obj/util/no_cfi_icall.stamp
  ldflags = /DEBUG /OPT$:ICF /OPT$:REF /SUBSYSTEM$:CONSOLE
  libs = kernel32.lib rpcrt4.lib advapi32.lib user32.lib version.lib winhttp.lib powrprof.lib shell32.lib
  frameworks =
  swiftmodules =
  output_extension = .exe
  output_dir = .
